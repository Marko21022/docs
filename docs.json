{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "Sway Documentation",
	"colors": {
		"primary": "#060606",
		"light": "#ffffff",
		"dark": "#060606"
	},
	"fonts": {
		"family": "Inter"
	},
  	"icons": {
    	"library": "lucide"
  	},
	"favicon": "/favicon.svg",
	"appearance": {
		"default": "dark"
	},
	"navigation": {
		"tabs": [
			{
				"tab": "Guides",
				"groups": [
					{
						"group": "Getting started",
						"pages": [
							"index",
							"Setting up"
						]
					},
					{
						"group": "Modules",
						"pages": [
							"modules/introduction",
							"modules/general",
							"modules/permissions",
							"modules/verification",
							"modules/moderation",
							"modules/staff-m",
							"modules/welcoming",
							"modules/anti-ping",
							"modules/sessions",
							"modules/suggestions",
							"modules/giveaways",
							"modules/logging",
							"modules/feedback",
							"modules/economy",
							"modules/game-i",
							"modules/starboard",
							"modules/sticky-r",
							"modules/tweeter"
						]
					}
				]
			}
		],
		"global": {
			"anchors": [
				{
					"anchor": "Documentation",
					"href": "https://docs.swaybot.dev/",
					"icon": "book-open-cover"
				}
			]
		}
	},
	"logo": {
		"light": "/logo/light.png",
		"dark": "/logo/dark.png"
	},
	"navbar": {
		"links": [
			{
				"label": "Support",
				"href": "https://swaybot.dev/support"
			}
		],
		"primary": {
			"type": "button",
			"label": "Dashboard",
			"href": "https://swaybot.dev/dashboard"
		}
	},
	"contextual": {
		"options": [
			"copy",
			"view"
		]
	},
	"footer": {
		"socials": {
			"x": "https://x.com/swaybotrblx",
			"github": "https://github.com/Sway-Bot",
			"discord": "https://swaybot.dev/support"
		}
	}
}